<form class="{{cssClass}} giharad-sheet-container" autocomplete="off">
    <header class="sheet-header">
        <div class="avatar-container">
            <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
        </div>
        <div class="header-details">
            <h1 class="charname">
                <input name="name" type="text" class="input-transparent" value="{{actor.name}}" placeholder="Nome" />
            </h1>
            <div class="header-row">
                <span>Classe:</span>
                <select name="system.classe" class="status-select">
                    <option value="" {{selected system.classe "" }}>(Nenhuma)</option>
                    <option value="Combatente" {{selected system.classe "Combatente" }}>Combatente</option>
                    <option value="Mentor" {{selected system.classe "Mentor" }}>Mentor</option>
                    <option value="Conjurador" {{selected system.classe "Conjurador" }}>Conjurador</option>
                    <option value="Zelote" {{selected system.classe "Zelote" }}>Zelote</option>
                </select>
                <span>Espécie:</span>
                <input type="text" name="system.especie" class="input-transparent w-auto" value="{{system.especie}}" />
            </div>
        </div>
        <div class="level-circle">
            <div class="level-label">NÍVEL</div>
            <input type="number" name="system.nivel" class="input-transparent" value="{{system.nivel}}" min="1" max="20" />
        </div>
    </header>

    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-tab="general">Geral</a>
        <a class="item" data-tab="skills">Combate/Habilidades</a>
        <a class="item" data-tab="magic">Magia</a>
        <a class="item" data-tab="inventory">Inventário</a>
        <a class="item" data-tab="notes">Notas</a>
    </nav>

    <section class="sheet-body">
        <!-- === GERAL === -->
        <div class="tab general" data-group="primary" data-tab="general">
            
            <div class="status-bars">
                <div class="bar-box pv">
                    <span class="stat-label">Vida (PV)</span>
                    <div class="bar-values">
                        <input type="number" name="system.pv.value" class="bar-input" value="{{system.pv.value}}" />
                        <span class="separator">/</span>
                        <input type="number" name="system.pv.max" class="bar-input" value="{{system.pv.max}}" readonly />
                    </div>
                </div>
                <div class="bar-box pa">
                    <span class="stat-label">Ação (PA)</span>
                    <div class="bar-values">
                        <input type="number" name="system.pa.value" class="bar-input" value="{{system.pa.value}}" />
                        <span class="separator">/</span>
                        <input type="number" name="system.pa.max" class="bar-input" value="{{system.pa.max}}" readonly />
                    </div>
                </div>
                <div class="bar-box pg">
                    <span class="stat-label">Grima (PG)</span>
                    <div class="bar-values">
                        <input type="number" name="system.pg.value" class="bar-input" value="{{system.pg.value}}" />
                        <span class="separator">/</span>
                        <input type="number" name="system.pg.max" class="bar-input" value="{{system.pg.max}}" readonly />
                    </div>
                </div>
                <div class="bar-box ph">
                    <span class="stat-label">Hafa (PH)</span>
                    <div class="bar-values">
                        <input type="number" name="system.ph.value" class="bar-input" value="{{system.ph.value}}" />
                        <span class="separator">/</span>
                        <input type="number" name="system.ph.max" class="bar-input" value="{{system.ph.max}}" readonly />
                    </div>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="stats-grid">
                <!-- Fisico -->
                <div class="stat-box" data-attr="fisico">
                    <span class="stat-label">FÍSICO</span>
                    <input type="number" name="system.bonus_fisico" class="bonus-input {{#if (gt system.bonus_fisico 0)}}bonus-positive{{/if}}{{#if (lt system.bonus_fisico 0)}}bonus-negative{{/if}}" value="{{system.bonus_fisico}}" title="Bônus/Penalidade" />
                    <div class="dice-container" data-attr="fisico" data-label="Físico">
                        <svg class="dice-svg" viewBox="0 0 100 100">{{{diceSvgContent system.fisico}}}</svg>
                        <span class="dice-label">{{system.fisico}}</span>
                        <select class="dice-select-hidden" name="system.fisico">
                            {{#each (list 4 6 8 10 12 20) as |faces|}}<option value="{{faces}}" {{selected ../system.fisico faces}}>d{{faces}}</option>{{/each}}
                        </select>
                    </div>
                    <div class="mini-dice-row">
                        <div class="mini-dice-container expertise-dice" title="Expertise (+d)">
                            <svg class="dice-svg {{#if (eq system.fisico_exp 0)}}empty-dice{{/if}}" viewBox="0 0 100 100">{{{diceSvgContent system.fisico_exp}}}</svg>
                            <span class="mini-dice-label">{{#unless (eq system.fisico_exp 0)}}{{system.fisico_exp}}{{/unless}}</span>
                            <select class="dice-select-hidden" name="system.fisico_exp">
                                <option value="0" {{selected system.fisico_exp 0}}>-</option>
                                {{#each (list 4 6 8 10 12) as |faces|}}<option value="{{faces}}" {{selected ../system.fisico_exp faces}}>d{{faces}}</option>{{/each}}
                            </select>
                        </div>
                        <div class="mini-dice-container incapacidade-dice" title="Incapacidade (-d)">
                            <svg class="dice-svg {{#if (eq system.fisico_inc 0)}}empty-dice{{/if}}" viewBox="0 0 100 100">{{{diceSvgContent system.fisico_inc}}}</svg>
                            <span class="mini-dice-label">{{#unless (eq system.fisico_inc 0)}}{{system.fisico_inc}}{{/unless}}</span>
                            <select class="dice-select-hidden" name="system.fisico_inc">
                                <option value="0" {{selected system.fisico_inc 0}}>-</option>
                                {{#each (list 4 6 8 10 12) as |faces|}}<option value="{{faces}}" {{selected ../system.fisico_inc faces}}>d{{faces}}</option>{{/each}}
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Mente -->
                <div class="stat-box" data-attr="mente">
                    <span class="stat-label">MENTE</span>
                    <input type="number" name="system.bonus_mente" class="bonus-input {{#if (gt system.bonus_mente 0)}}bonus-positive{{/if}}{{#if (lt system.bonus_mente 0)}}bonus-negative{{/if}}" value="{{system.bonus_mente}}" title="Bônus/Penalidade" />
                    <div class="dice-container" data-attr="mente" data-label="Mente">
                        <svg class="dice-svg" viewBox="0 0 100 100">{{{diceSvgContent system.mente}}}</svg>
                        <span class="dice-label">{{system.mente}}</span>
                        <select class="dice-select-hidden" name="system.mente">
                            {{#each (list 4 6 8 10 12 20) as |faces|}}<option value="{{faces}}" {{selected ../system.mente faces}}>d{{faces}}</option>{{/each}}
                        </select>
                    </div>
                    <div class="mini-dice-row">
                        <div class="mini-dice-container expertise-dice" title="Expertise (+d)">
                            <svg class="dice-svg {{#if (eq system.mente_exp 0)}}empty-dice{{/if}}" viewBox="0 0 100 100">{{{diceSvgContent system.mente_exp}}}</svg>
                            <span class="mini-dice-label">{{#unless (eq system.mente_exp 0)}}{{system.mente_exp}}{{/unless}}</span>
                            <select class="dice-select-hidden" name="system.mente_exp">
                                <option value="0" {{selected system.mente_exp 0}}>-</option>
                                {{#each (list 4 6 8 10 12) as |faces|}}<option value="{{faces}}" {{selected ../system.mente_exp faces}}>d{{faces}}</option>{{/each}}
                            </select>
                        </div>
                        <div class="mini-dice-container incapacidade-dice" title="Incapacidade (-d)">
                            <svg class="dice-svg {{#if (eq system.mente_inc 0)}}empty-dice{{/if}}" viewBox="0 0 100 100">{{{diceSvgContent system.mente_inc}}}</svg>
                            <span class="mini-dice-label">{{#unless (eq system.mente_inc 0)}}{{system.mente_inc}}{{/unless}}</span>
                            <select class="dice-select-hidden" name="system.mente_inc">
                                <option value="0" {{selected system.mente_inc 0}}>-</option>
                                {{#each (list 4 6 8 10 12) as |faces|}}<option value="{{faces}}" {{selected ../system.mente_inc faces}}>d{{faces}}</option>{{/each}}
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Carisma -->
                <div class="stat-box" data-attr="carisma">
                    <span class="stat-label">CARISMA</span>
                    <input type="number" name="system.bonus_carisma" class="bonus-input {{#if (gt system.bonus_carisma 0)}}bonus-positive{{/if}}{{#if (lt system.bonus_carisma 0)}}bonus-negative{{/if}}" value="{{system.bonus_carisma}}" title="Bônus/Penalidade" />
                    <div class="dice-container" data-attr="carisma" data-label="Carisma">
                        <svg class="dice-svg" viewBox="0 0 100 100">{{{diceSvgContent system.carisma}}}</svg>
                        <span class="dice-label">{{system.carisma}}</span>
                        <select class="dice-select-hidden" name="system.carisma">
                            {{#each (list 4 6 8 10 12 20) as |faces|}}<option value="{{faces}}" {{selected ../system.carisma faces}}>d{{faces}}</option>{{/each}}
                        </select>
                    </div>
                    <div class="mini-dice-row">
                        <div class="mini-dice-container expertise-dice" title="Expertise (+d)">
                            <svg class="dice-svg {{#if (eq system.carisma_exp 0)}}empty-dice{{/if}}" viewBox="0 0 100 100">{{{diceSvgContent system.carisma_exp}}}</svg>
                            <span class="mini-dice-label">{{#unless (eq system.carisma_exp 0)}}{{system.carisma_exp}}{{/unless}}</span>
                            <select class="dice-select-hidden" name="system.carisma_exp">
                                <option value="0" {{selected system.carisma_exp 0}}>-</option>
                                {{#each (list 4 6 8 10 12) as |faces|}}<option value="{{faces}}" {{selected ../system.carisma_exp faces}}>d{{faces}}</option>{{/each}}
                            </select>
                        </div>
                        <div class="mini-dice-container incapacidade-dice" title="Incapacidade (-d)">
                            <svg class="dice-svg {{#if (eq system.carisma_inc 0)}}empty-dice{{/if}}" viewBox="0 0 100 100">{{{diceSvgContent system.carisma_inc}}}</svg>
                            <span class="mini-dice-label">{{#unless (eq system.carisma_inc 0)}}{{system.carisma_inc}}{{/unless}}</span>
                            <select class="dice-select-hidden" name="system.carisma_inc">
                                <option value="0" {{selected system.carisma_inc 0}}>-</option>
                                {{#each (list 4 6 8 10 12) as |faces|}}<option value="{{faces}}" {{selected ../system.carisma_inc faces}}>d{{faces}}</option>{{/each}}
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Astucia -->
                <div class="stat-box" data-attr="reflexos">
                    <span class="stat-label">REFLEXOS</span>
                    <input type="number" name="system.bonus_reflexos" class="bonus-input {{#if (gt system.bonus_reflexos 0)}}bonus-positive{{/if}}{{#if (lt system.bonus_reflexos 0)}}bonus-negative{{/if}}" value="{{system.bonus_reflexos}}" title="Bônus/Penalidade" />
                    <div class="dice-container" data-attr="reflexos" data-label="Reflexos">
                        <svg class="dice-svg" viewBox="0 0 100 100">{{{diceSvgContent system.reflexos}}}</svg>
                        <span class="dice-label">{{system.reflexos}}</span>
                        <select class="dice-select-hidden" name="system.reflexos">
                            {{#each (list 4 6 8 10 12 20) as |faces|}}<option value="{{faces}}" {{selected ../system.reflexos faces}}>d{{faces}}</option>{{/each}}
                        </select>
                    </div>
                    <div class="mini-dice-row">
                        <div class="mini-dice-container expertise-dice" title="Expertise (+d)">
                            <svg class="dice-svg {{#if (eq system.reflexos_exp 0)}}empty-dice{{/if}}" viewBox="0 0 100 100">{{{diceSvgContent system.reflexos_exp}}}</svg>
                            <span class="mini-dice-label">{{#unless (eq system.reflexos_exp 0)}}{{system.reflexos_exp}}{{/unless}}</span>
                            <select class="dice-select-hidden" name="system.reflexos_exp">
                                <option value="0" {{selected system.reflexos_exp 0}}>-</option>
                                {{#each (list 4 6 8 10 12) as |faces|}}<option value="{{faces}}" {{selected ../system.reflexos_exp faces}}>d{{faces}}</option>{{/each}}
                            </select>
                        </div>
                        <div class="mini-dice-container incapacidade-dice" title="Incapacidade (-d)">
                            <svg class="dice-svg {{#if (eq system.reflexos_inc 0)}}empty-dice{{/if}}" viewBox="0 0 100 100">{{{diceSvgContent system.reflexos_inc}}}</svg>
                            <span class="mini-dice-label">{{#unless (eq system.reflexos_inc 0)}}{{system.reflexos_inc}}{{/unless}}</span>
                            <select class="dice-select-hidden" name="system.reflexos_inc">
                                <option value="0" {{selected system.reflexos_inc 0}}>-</option>
                                {{#each (list 4 6 8 10 12) as |faces|}}<option value="{{faces}}" {{selected ../system.reflexos_inc faces}}>d{{faces}}</option>{{/each}}
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Defesa e Marcadores -->
            <div class="panel-box-bordered flex-row justify-between mb-15">
                <div class="defesa-box text-center" style="display: flex; flex-direction: column;">
                    <span class="stat-label">DEFESA</span>
                    <div style="display: flex; gap: 4px; justify-content: center; align-items: center; margin-top: 5px;">
                        <input type="number" class="bar-input" style="width: 32px; font-weight:bold; color: white; background: rgba(255,255,255,0.05); border-radius: 4px;" value="{{system.defesa}}" readonly title="Total" />
                        <span style="font-weight: bold; margin: 0 2px;">=</span>
                        <input type="number" name="system.defesa_base" class="bar-input" style="width: 25px; font-size: 0.9em;" value="{{system.defesa_base}}" title="Defesa Base" />
                        <span style="color: var(--green); font-weight:bold; margin: 0 1px;">+</span>
                        <input type="number" name="system.defesa_bonus" class="bar-input" style="width: 25px; color: var(--green); font-size: 0.9em;" value="{{system.defesa_bonus}}" title="Bônus Manual" />
                        <span style="color: var(--red-accent); font-weight:bold; margin: 0 1px;">-</span>
                        <input type="number" name="system.defesa_penalidade" class="bar-input" style="width: 25px; color: var(--red-accent); font-size: 0.9em;" value="{{system.defesa_penalidade}}" title="Penalidade Manual" />
                    </div>
                </div>
                <div class="markers-box text-center">
                    <span class="stat-label">FADIGA</span><br>
                    <input type="checkbox" name="system.fadiga1" {{checked system.fadiga1}}>
                    <input type="checkbox" name="system.fadiga2" {{checked system.fadiga2}}>
                    <input type="checkbox" name="system.fadiga3" {{checked system.fadiga3}}>
                    <input type="checkbox" name="system.fadiga4" {{checked system.fadiga4}}>
                </div>
                <div class="markers-box text-center">
                    <span class="stat-label">MORTE</span><br>
                    <input type="checkbox" name="system.morte1" {{checked system.morte1}}>
                    <input type="checkbox" name="system.morte2" {{checked system.morte2}}>
                    <input type="checkbox" name="system.morte3" {{checked system.morte3}}>
                    <input type="checkbox" name="system.morte4" {{checked system.morte4}}>
                </div>
                <div class="markers-box text-center">
                    <span class="stat-label">CICATRIZES</span><br>
                    <input type="checkbox" name="system.cicatriz1" {{checked system.cicatriz1}}>
                    <input type="checkbox" name="system.cicatriz2" {{checked system.cicatriz2}}>
                    <input type="checkbox" name="system.cicatriz3" {{checked system.cicatriz3}}>
                    <input type="checkbox" name="system.cicatriz4" {{checked system.cicatriz4}}>
                </div>
            </div>

            <!-- Competencias -->
            <div class="panel-box-bordered">
                <h3 class="section-title">Competências</h3>
                
                <div class="competencias-grid">
                    <!-- Cabeçalhos das Colunas -->
                    <div class="competencia-row" style="border-bottom: none; opacity: 0.8; padding-bottom: 0;">
                        <span style="margin-left: auto; width: 25px; text-align: center; color: var(--green); font-weight: bold;" title="Treinamento">T</span>
                        <span style="width: 25px; text-align: center; color: var(--blue); font-weight: bold; margin-left: 5px;" title="Avulso">A</span>
                        <span style="width: 25px; text-align: center; color: var(--red-accent); font-weight: bold; margin-left: 5px;" title="Penalidade">P</span>
                    </div>
                    <div class="competencia-row" style="border-bottom: none; opacity: 0.8; padding-bottom: 0;">
                        <span style="margin-left: auto; width: 25px; text-align: center; color: var(--green); font-weight: bold;" title="Treinamento">T</span>
                        <span style="width: 25px; text-align: center; color: var(--blue); font-weight: bold; margin-left: 5px;" title="Avulso">A</span>
                        <span style="width: 25px; text-align: center; color: var(--red-accent); font-weight: bold; margin-left: 5px;" title="Penalidade">P</span>
                    </div>

                    {{#each competencias as |comp|}}
                    <div class="competencia-row">
                        <a class="comp-roll" data-name="{{comp.name}}" title="Rolar {{comp.name}}"><i class="fas fa-dice-d20"></i></a>
                        <span class="comp-name" style="min-width: 100px;">{{comp.name}}</span>
                        <select name="system.comp_attrs.{{comp.name}}" class="comp-attr-select" style="font-size: 0.8em; width: 65px; margin-right: auto; border-bottom: none; background: transparent; color: var(--text-muted);">
                            <option value="fisico" {{selected comp.atributo "fisico"}}>Físico</option>
                            <option value="reflexos" {{selected comp.atributo "reflexos"}}>Reflexos</option>
                            <option value="mente" {{selected comp.atributo "mente"}}>Mente</option>
                            <option value="carisma" {{selected comp.atributo "carisma"}}>Carisma</option>
                        </select>
                        <input type="number" name="system.competencias.{{comp.name}}.treinamento" class="comp-input" style="width: 25px; color: var(--green);" value="{{comp.treinamento}}" title="Treinamento" />
                        <input type="number" name="system.competencias.{{comp.name}}.avulso" class="comp-input" style="width: 25px; margin-left: 5px; color: var(--blue);" value="{{comp.avulso}}" title="Avulso" />
                        <input type="number" name="system.competencias.{{comp.name}}.armadura" class="comp-input" style="width: 25px; margin-left: 5px; color: var(--red-accent);" value="{{comp.armadura}}" title="Penalidade" />
                    </div>
                    {{/each}}

                    <div class="competencia-row" style="grid-column: span 2; border-bottom: 1px solid var(--border-color); padding-top: 10px; margin-bottom: 5px; opacity: 0.8;">
                        <span style="font-weight: bold; margin-right: 15px; color: var(--text-light);">Extras:</span>
                        <a class="generic-add" data-type="profissoes" title="Adicionar Profissão" style="cursor: pointer; margin-right: 15px;"><i class="fas fa-plus"></i> Profissão</a>
                        <a class="generic-add" data-type="idiomas" title="Adicionar Idioma" style="cursor: pointer;"><i class="fas fa-plus"></i> Idioma</a>
                    </div>

                    {{#each system.competencias.profissoes as |comp id|}}
                    <div class="competencia-row">
                        <a class="comp-roll generic" data-type="profissoes" data-id="{{id}}" title="Rolar Profissão"><i class="fas fa-dice-d20"></i></a>
                        <input type="text" name="system.competencias.profissoes.{{id}}.name" class="input-transparent" style="min-width: 80px; max-width: 105px; font-size: 0.9em; font-weight: bold; color: white;" value="{{comp.name}}" placeholder="Nome da Profissão" />
                        <select name="system.comp_attrs.prof_attrs.{{id}}" class="comp-attr-select" style="font-size: 0.8em; width: 60px; margin-right: auto; margin-left: 5px; border-bottom: none; background: transparent; color: var(--text-muted);">
                            <option value="fisico" {{selected (lookup ../system.comp_attrs.prof_attrs id) "fisico"}}>Físico</option>
                            <option value="reflexos" {{selected (lookup ../system.comp_attrs.prof_attrs id) "reflexos"}}>Reflexos</option>
                            <option value="mente" {{selected (lookup ../system.comp_attrs.prof_attrs id) "mente"}}>Mente</option>
                            <option value="carisma" {{selected (lookup ../system.comp_attrs.prof_attrs id) "carisma"}}>Carisma</option>
                        </select>
                        <input type="number" name="system.competencias.profissoes.{{id}}.treinamento" class="comp-input" style="width: 25px; color: var(--green);" value="{{comp.treinamento}}" title="Treinamento" />
                        <input type="number" name="system.competencias.profissoes.{{id}}.avulso" class="comp-input" style="width: 25px; margin-left: 5px; color: var(--blue);" value="{{comp.avulso}}" title="Avulso" />
                        <input type="number" name="system.competencias.profissoes.{{id}}.armadura" class="comp-input" style="width: 25px; margin-left: 5px; color: var(--red-accent);" value="{{comp.armadura}}" title="Penalidade" />
                        <a class="generic-delete" data-type="profissoes" data-id="{{id}}" title="Remover" style="margin-left: 5px; color: var(--red-accent); cursor: pointer;"><i class="fas fa-trash"></i></a>
                    </div>
                    {{/each}}
                    
                    {{#each system.competencias.idiomas as |comp id|}}
                    <div class="competencia-row">
                        <a class="comp-roll generic" data-type="idiomas" data-id="{{id}}" title="Rolar Idioma"><i class="fas fa-dice-d20"></i></a>
                        <input type="text" name="system.competencias.idiomas.{{id}}.name" class="input-transparent" style="min-width: 80px; max-width: 105px; font-size: 0.9em; font-weight: bold; color: white;" value="{{comp.name}}" placeholder="Nome do Idioma" />
                        <select name="system.comp_attrs.idio_attrs.{{id}}" class="comp-attr-select" style="font-size: 0.8em; width: 60px; margin-right: auto; margin-left: 5px; border-bottom: none; background: transparent; color: var(--text-muted);">
                            <option value="fisico" {{selected (lookup ../system.comp_attrs.idio_attrs id) "fisico"}}>Físico</option>
                            <option value="reflexos" {{selected (lookup ../system.comp_attrs.idio_attrs id) "reflexos"}}>Reflexos</option>
                            <option value="mente" {{selected (lookup ../system.comp_attrs.idio_attrs id) "mente"}}>Mente</option>
                            <option value="carisma" {{selected (lookup ../system.comp_attrs.idio_attrs id) "carisma"}}>Carisma</option>
                        </select>
                        <input type="number" name="system.competencias.idiomas.{{id}}.treinamento" class="comp-input" style="width: 25px; color: var(--green);" value="{{comp.treinamento}}" title="Treinamento" />
                        <input type="number" name="system.competencias.idiomas.{{id}}.avulso" class="comp-input" style="width: 25px; margin-left: 5px; color: var(--blue);" value="{{comp.avulso}}" title="Avulso" />
                        <input type="number" name="system.competencias.idiomas.{{id}}.armadura" class="comp-input" style="width: 25px; margin-left: 5px; color: var(--red-accent);" value="{{comp.armadura}}" title="Penalidade" />
                        <a class="generic-delete" data-type="idiomas" data-id="{{id}}" title="Remover" style="margin-left: 5px; color: var(--red-accent); cursor: pointer;"><i class="fas fa-trash"></i></a>
                    </div>
                    {{/each}}
                </div>
            </div>

        </div>

        <!-- === COMBAT / SKILLS === -->
        <div class="tab skills" data-group="primary" data-tab="skills">
            <div class="panel-box-bordered">
                <h3 class="section-title">Ataques <a class="item-create right" data-type="ataque"><i class="fas fa-plus"></i></a></h3>
                <div class="item-list">
                    {{#each actor.items as |item|}}
                    {{#if (eq item.type 'ataque')}}
                    <div class="item-row" data-item-id="{{item._id}}">
                        <a class="item-roll" data-roll-type="acerto" title="Acerto"><i class="fas fa-crosshairs"></i></a>
                        <a class="item-roll" data-roll-type="dano" title="Dano"><i class="fas fa-tint"></i></a>
                        <a class="item-roll" data-roll-type="explosivo" title="Dano Explosivo / Crítico"><i class="fas fa-fire text-orange"></i></a>
                        <a class="item-roll" data-roll-type="desc" title="Enviar para o Chat"><i class="fas fa-comment"></i></a>
                        <span class="item-name">{{item.name}} ({{item.system.dano}})</span>
                        <div class="item-controls">
                            <a class="item-edit"><i class="fas fa-edit"></i></a>
                            <a class="item-delete"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    {{/if}}
                    {{/each}}
                </div>
            </div>
            
            <div class="panel-box-bordered mt-15">
                <h3 class="section-title">Habilidades <a class="item-create right" data-type="habilidade"><i class="fas fa-plus"></i></a></h3>
                <div class="item-list">
                    {{#each actor.items as |item|}}
                    {{#if (eq item.type 'habilidade')}}
                    <div class="item-row" data-item-id="{{item._id}}">
                        <a class="item-roll" data-roll-type="desc" title="Enviar para o Chat"><i class="fas fa-comment"></i></a>
                        <span class="item-name">{{item.name}}</span>
                        <div class="item-controls">
                            <a class="item-edit"><i class="fas fa-edit"></i></a>
                            <a class="item-delete"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    {{/if}}
                    {{/each}}
                </div>
            </div>
        </div>

        <!-- === MAGIC === -->
        <div class="tab magic" data-group="primary" data-tab="magic">
            
            <!-- Spell Slots -->
            <div class="panel-box-bordered mb-15">
                <div class="flex-row justify-center align-center mb-10">
                    <h3 class="section-title" style="margin: 0;">Espaços de Magia</h3>
                </div>
                <div class="slots-grid grid grid-2col text-center" style="gap: 5px; max-width: 300px; margin: 0 auto;">
                    <div class="slot-box">
                        <span class="stat-label">Círculo 1</span>
                        <div class="bar-values justify-center mt-5">
                            <input type="number" name="system.slots.l1.value" class="bar-input" style="width: 25px;" value="{{system.slots.l1.value}}" />
                            <span class="separator">/</span>
                            <input type="number" name="system.slots.l1.max" class="bar-input" style="width: 25px; opacity: 0.7;" value="{{system.slots.l1.max}}" readonly />
                        </div>
                    </div>
                    <div class="slot-box">
                        <span class="stat-label">Círculo 2</span>
                        <div class="bar-values justify-center mt-5">
                            <input type="number" name="system.slots.l2.value" class="bar-input" style="width: 25px;" value="{{system.slots.l2.value}}" />
                            <span class="separator">/</span>
                            <input type="number" name="system.slots.l2.max" class="bar-input" style="width: 25px; opacity: 0.7;" value="{{system.slots.l2.max}}" readonly />
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel-box-bordered">
                <h3 class="section-title">Grimório <a class="item-create right" data-type="feitico"><i class="fas fa-plus"></i></a></h3>
                <div class="item-list">
                    {{#each actor.items as |item|}}
                    {{#if (eq item.type 'feitico')}}
                    <div class="item-row" data-item-id="{{item._id}}">
                        <a class="item-roll" data-roll-type="desc" title="Enviar para o Chat"><i class="fas fa-comment"></i></a>
                        <span class="item-name">{{item.name}} (Círculo {{item.system.circulo}})</span>
                        <div class="item-controls">
                            <a class="item-edit"><i class="fas fa-edit"></i></a>
                            <a class="item-delete"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    {{/if}}
                    {{/each}}
                </div>
            </div>
        </div>

        <!-- === INVENTORY === -->
        <div class="tab inventory" data-group="primary" data-tab="inventory">
            <div class="panel-box-bordered">
                <div class="dinheiro-box flex-row justify-center mb-15 text-center">
                    <div>
                        <span class="stat-label" title="Moedas de Prata">Punhados (P$)</span>
                        <input type="number" name="system.dinheiro.punhados" value="{{system.dinheiro.punhados}}" class="bar-input" style="width: 80px;" />
                    </div>
                </div>

                <h3 class="section-title">Mochila <a class="item-create right" data-type="item"><i class="fas fa-plus"></i></a></h3>
                <div class="load-bar-container mb-10 text-center">
                    <span class="stat-label">Carga Total: {{system.carga.value}} / {{system.carga.max}}</span>
                </div>
                <div class="item-list">
                    {{#each actor.items as |item|}}
                    {{#if (eq item.type 'item')}}
                    <div class="item-row" data-item-id="{{item._id}}">
                        <a class="item-roll" data-roll-type="desc" title="Enviar para o Chat"><i class="fas fa-comment"></i></a>
                        <span class="item-name">{{item.name}} (x{{item.system.qtd}})</span>
                        <div class="item-controls">
                            <a class="item-edit"><i class="fas fa-edit"></i></a>
                            <a class="item-delete"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    {{/if}}
                    {{/each}}
                </div>
            </div>
        </div>

        <!-- === NOTES === -->
        <div class="tab notes" data-group="primary" data-tab="notes">
            <div class="panel-box-bordered">
                {{editor enrichedNotas target="system.notas" button=true editable=editable engine="prosemirror"}}
            </div>
        </div>

    </section>
</form>
